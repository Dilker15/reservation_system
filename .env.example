
# =============================================================
# Application
# =============================================================
APP_PORT=4000
APP_URL=http://localhost:4000
FRONT_END_URL=http://localhost:5173

# =============================================================
# Database (PostgreSQL)
# =============================================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=reservation_db
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password

# =============================================================
# Authentication
# =============================================================
TOKEN_SECRET_KEY=your_token_secret_key
EXPIRATION_TOKEN=1h
SEED_TOKEN=your_seed_token

# =============================================================
# Mail (SMTP)
# =============================================================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=465
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_email_password

# =============================================================
# Redis
# =============================================================
REDIS_URL=redis://localhost:6379
REDIS_CACHE_URL=redis://localhost:6380

# =============================================================
# Cloudinary
# =============================================================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# =============================================================
# Mercado Pago
# =============================================================
MERCADO_PAGO_KEY=your_mercadopago_key
MERCADO_PAGO_TOKEN=your_mercadopago_token
MERCADO_PAGO_WEBHOOK_SECRET=your_webhook_secret
MERCADO_PAGO_CLIENT_ID=your_client_id
MERCADO_PAGO_CLIENT_SECRET=your_client_secret

# =============================================================
# Stripe
# =============================================================
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret
STRIPE_CLIENT_ID=your_stripe_client_id

# =============================================================
# Redirect URLs (payment flow)
# =============================================================
BACK_URL_SUCCESS=http://localhost:5173/success
BACK_URL_FAILURE=http://localhost:5173/error
BACK_URL_PENDING=http://localhost:5173/pending


